{
  "functions": {
    "api/data.js": { "memory": 128, "maxDuration": 10 },
    "api/auth.js": { "memory": 128, "maxDuration": 10 },
    "api/photo.js": { "memory": 256, "maxDuration": 15 }
  },
  "routes": [
    { "src": "/api/data", "dest": "/api/data.js" },
    { "src": "/api/auth", "dest": "/api/auth.js" },
    { "src": "/api/photo", "dest": "/api/photo.js" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
